# MongoDB
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/obsidian

# JWT
JWT_SECRET=ponTuSecretoAqui

# Google OAuth
GOOGLE_CLIENT_ID=tuClientId.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tuClientSecret

# Frontend
FRONTEND_URL=http://localhost:5173

# Puerto del servidor
PORT=3000

# Admin (para el seed)
ADMIN_EMAIL=admin@obsidian.com
ADMIN_PASSWORD=cambiaEstaPorUnaSegura
ADMIN_NAME=Admin

# Cloudinary (para subida de imagenes)
CLOUDINARY_CLOUD_NAME=tuCloudName
CLOUDINARY_API_KEY=tuApiKey
CLOUDINARY_API_SECRET=tuApiSecret